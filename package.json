{
    "version":  "0.1.0",
    "name":  "ruleforge-monorepo",
    "scripts":  {
                    "lint":  "npm run lint --workspaces --if-present",
                    "build":  "npm run build --workspaces",
                    "package:cli":  "cd packages/cli \u0026\u0026 npm run package",
                    "test":  "npm run test --workspaces --if-present",
                    "package:plugin":  "cd packages/adapter-trae \u0026\u0026 npm run package",
                    "dev":  "npm run dev --workspaces --if-present",
                    
                    "electron:dev":  "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron electron/main.js\"",
                    "electron:build":  "npm run build && electron-builder",
                    "electron:build:win":  "npm run build && electron-builder --win",
                    "electron:build:win-portable":  "npm run build && electron-builder --win portable",
                    "electron:build:win-zip":  "npm run build && electron-builder --win zip",
                    "electron:pack":  "npm run build && electron-builder --dir",
                    "dist":  "npm run electron:build",
                    "dist:win":  "npm run electron:build:win",
                    "dist:portable":  "npm run electron:build:win-portable",
                    "dist:zip":  "npm run electron:build:win-zip",
                    "postinstall":  "electron-builder install-app-deps"
                },
    "devDependencies":  {
                            "concurrently":  "^8.2.2",
                            "@typescript-eslint/eslint-plugin":  "^7.0.0",
                            "@typescript-eslint/parser":  "^7.0.0",
                            "electron":  "^28.0.0",
                            "electron-builder":  "^24.0.0",
                            "electron-is-dev":  "^2.0.0",
                            "wait-on":  "^7.0.0"
                        },
    "workspaces":  [
                       "packages/*"
                   ],
    "private":  true
}

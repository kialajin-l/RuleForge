    "clean": "rm -f demo-session.jsonl demo-report.json complete-flow.js"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "cli-progress": "^3.12.0",
    "execa": "^8.0.1"
  },
  "devDependencies": {
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  },
  "keywords": [
    "ruleforge",
    "demo",
    "code-analysis",
    "pattern-recognition"
  ],

{
  "name": "@ruleforge/core-demo",
  "version": "1.0.0",
  "description": "RuleForge 完整流程演示",
  "type": "module",
  "main": "complete-flow.js",
  "bin": {
    "ruleforge-demo": "./complete-flow.js"
  },
  "scripts": {
    "demo": "tsx complete-flow.ts",
    "build": "tsc complete-flow.ts --outDir . --target es2020 --module es2020 --moduleResolution node",
